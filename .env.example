SECRET_KEY=django-insecure-cambia-esto-en-produccion-genera-una-llave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI
OPENAI_API_KEY=sk-...tu-api-key-aqui

# Modelo de IA (opciones: gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
AI_MODEL=gpt-4o

# Email (Plan A onboarding)
# Desarrollo local (emails en consola):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=MagicBook <no-reply@magicbook.local>
SERVER_EMAIL=MagicBook <no-reply@magicbook.local>

